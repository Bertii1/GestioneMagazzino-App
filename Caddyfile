# Caddyfile per produzione
# Sostituire {$DOMAIN} con il dominio reale (es. api.tuodominio.it)
# Caddy gestisce automaticamente HTTPS via Let's Encrypt

{$DOMAIN:localhost} {
	# Blocca /metrics dall'esterno (Prometheus scrape via rete Docker interna)
	handle /metrics {
		respond 403
	}

	# Grafana — dashboard con auth propria
	handle /grafana* {
		reverse_proxy grafana:3000
	}

	# API principale
	handle {
		reverse_proxy server:3000
	}

	# Logging
	log {
		output stdout
		format json
	}

	# Compressione
	encode gzip zstd
}

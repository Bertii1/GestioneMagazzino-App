# ─── Server ───��──────────────────────────���─────────────────────────
NODE_ENV=production
PORT=3000

# ─── MongoDB ──────────���───────────────────────────���────────────────
MONGO_USER=admin
MONGO_PASSWORD=          # OBBLIGATORIO — password robusta per MongoDB
MONGODB_URI=mongodb://admin:TUA_PASSWORD@mongo:27017/gestione_magazzino?authSource=admin

# ─── JWT ─────��────────────────────────────���──────────────────────��─
JWT_SECRET=              # OBBLIGATORIO — genera con: openssl rand -hex 32
JWT_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────────────────────────────
# In produzione: origini consentite separate da virgola
# Es: https://app.tuodominio.it,https://admin.tuodominio.it
CORS_ORIGIN=*

# ─── Admin iniziale ────────────────────────────────────────────────
ADMIN_EMAIL=admin@magazzino.local
ADMIN_PASSWORD=admin123   # Cambiala al primo login!

# ─── Whisper ASR ───────────────────────────────────────────────────
WHISPER_URL=http://whisper-asr:9000

# ─── Gemini AI (riconoscimento prodotti da foto) ──────────────────
GEMINI_API_KEY=           # Ottieni da: https://aistudio.google.com/apikey

# ─── Caddy / Dominio ──────────────────────────────────────────────
DOMAIN=localhost         # In produzione: api.tuodominio.it

# ─── Sviluppo locale ──────────────────────────────────────────────
# HOST_IP=192.168.0.xxx  # IP host per Expo Metro Bundler (profilo dev)

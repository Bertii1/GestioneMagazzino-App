# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_USER=admin
MONGO_PASSWORD=cambia_questa_password

# ─── Server ───────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_questo_segreto_lungo_e_casuale
JWT_EXPIRES_IN=7d
NODE_ENV=production

# ─── Mobile Dev (opzionale) ───────────────────────────────────────────────────
# IP del tuo computer sulla LAN (dove gira Docker)
# Trovalo con: ip route get 1 | awk '{print $7; exit}' (Linux)
#              ipconfig getifaddr en0 (macOS)
HOST_IP=192.168.1.100
